{
  "name": "@zillingen/custom-fe-fwk",
  "version": "1.0.0",
  "description": "A frontend framework to teach web developers how frontend frameworks work.",
  "keywords": [
    "frontend",
    "framework",
    "book",
    "learning",
    "web",
    "development"
  ],
  "main": "dist/fe-fwk.js",
  "type": "module",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/fe-fwk.js",
    "dist/types/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zillingen/custom-fe-fwk.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^22.1.0",
    "rollup": "^3.28.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-filesize": "^10.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  }
}
